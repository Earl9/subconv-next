config service 'service'
	# V1 package defaults target a router-local service managed by procd.
	option enabled '1'
	option host '0.0.0.0'
	option port '9876'
	option data_dir '/etc/subconv-next/data'
	# Set this when links are accessed through a DNS name, reverse proxy, or non-default port.
	option public_base_url ''
	option log_level 'info'

config render 'mihomo'
	# Keep node names as "{emoji} {sourceName}｜{rawNodeName}" and do not generate region groups.
	option source_prefix '1'
	option rule_group_node_mode 'full'
	option enable_region_groups '0'
