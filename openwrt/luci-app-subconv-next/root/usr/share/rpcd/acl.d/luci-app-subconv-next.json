{
	"luci-app-subconv-next": {
		"description": "Grant access to the SubConv Next service RPC",
		"read": {
			"cgi-io": [ "download" ],
			"file": {
				"/tmp/subconv-next-backup.*": [ "read" ]
			},
			"ubus": {
				"luci.subconv": [ "status", "get_config", "get_autostart", "logs_read", "logs_download", "backup_export" ]
			}
		},
		"write": {
			"ubus": {
				"luci.subconv": [ "start", "stop", "restart", "set_config", "set_autostart", "logs_clear", "backup_export_cleanup", "backup_upload_begin", "backup_upload_chunk", "backup_check", "backup_restore", "backup_upload_cancel" ]
			}
		}
	}
}
